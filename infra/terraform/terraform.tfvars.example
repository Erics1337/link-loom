project_name = "link-loom-prod"
aws_region   = "us-east-1"

# If backend_image is empty, Terraform builds apps/backend/Dockerfile.lambda,
# pushes it to ECR, and uses image_tag for all Lambda functions.
backend_image       = ""
image_tag           = "v1"
build_backend_image = true

api_memory_mb              = 512
api_timeout_seconds        = 30
worker_memory_mb           = 1024
worker_timeout_seconds     = 120
clustering_memory_mb       = 2048
clustering_timeout_seconds = 900

free_tier_limit                   = 500
cluster_name_concurrency          = 4
cluster_name_max_retries          = 5
cluster_name_base_backoff_ms      = 400
cluster_name_min_bookmarks_for_ai = 12

# Required app secrets.
supabase_url              = "https://YOUR_PROJECT.supabase.co"
supabase_service_role_key = "YOUR_SUPABASE_SERVICE_ROLE_KEY"
openai_api_key            = "YOUR_OPENAI_API_KEY"

resource_tags = {
  Environment = "prod"
  App         = "link-loom"
}
