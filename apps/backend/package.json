    "axios": "^1.6.0",
    "cheerio": "1.0.0",
    "dotenv": "^16.3.1",
    "fastify": "^4.24.3",
    "ml-kmeans": "^6.0.0",
    "openai": "^4.14.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@link-loom/tsconfig": "workspace:*",
    "@types/aws-lambda": "^8.10.159",
    "@types/node": "^20.8.10",
    "@vitest/ui": "^4.0.18",
    "pino-pretty": "^13.1.3",
