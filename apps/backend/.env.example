# Supabase Configuration
SUPABASE_URL=http://127.0.0.1:54421
SUPABASE_SERVICE_ROLE_KEY=your_local_supabase_service_role_key_from_npx_supabase_status
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54422/postgres

# OpenAI API Key (for embeddings)
OPENAI_API_KEY=your_openai_api_key

# Queue Configuration
# Use inline for local development, sqs for Lambda production.
QUEUE_DRIVER=inline
INGEST_QUEUE_URL=
ENRICHMENT_QUEUE_URL=
EMBEDDING_QUEUE_URL=
CLUSTERING_QUEUE_URL=

# Free tier bookmark cap for local/dev testing (default in code is 500)
# Set higher locally (e.g. 10000) to test large imports without premium.
FREE_TIER_LIMIT=500

# Cluster name generation rate-limit controls
# Lower concurrency if you see OpenAI 429 errors during clustering.
CLUSTER_NAME_CONCURRENCY=4
CLUSTER_NAME_MAX_RETRIES=5
CLUSTER_NAME_BASE_BACKOFF_MS=400
CLUSTER_NAME_MIN_BOOKMARKS_FOR_AI=12
